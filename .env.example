# Patient Survival Prediction — environment variables
# Copy to .env and fill in your values.

# ── Model settings ────────────────────────────────────────────────
RANDOM_SEED=42
CV_FOLDS=5
TEST_SIZE=0.2

# ── XGBoost ───────────────────────────────────────────────────────
XGB_N_ESTIMATORS=200
XGB_MAX_DEPTH=4
XGB_LR=0.05

# ── LightGBM ──────────────────────────────────────────────────────
LGBM_N_ESTIMATORS=200
LGBM_MAX_DEPTH=4
LGBM_LR=0.05

# ── SHAP ──────────────────────────────────────────────────────────
SHAP_TOP_N=10
SHAP_LOCAL_N=5

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
